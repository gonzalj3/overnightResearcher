<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.research.imsg-watcher</string>

	<key>Program</key>
	<string>/opt/homebrew/bin/imsg</string>

	<key>ProgramArguments</key>
	<array>
		<string>/opt/homebrew/bin/imsg</string>
		<string>watch</string>
		<string>--chat-id</string>
		<string>4</string>
		<string>--json</string>
	</array>

	<key>StandardOutPath</key>
	<string>/Users/jmg/GitHub/overnightResearcher/research/logs/imsg-watch-stdout.log</string>

	<key>StandardErrorPath</key>
	<string>/Users/jmg/GitHub/overnightResearcher/research/logs/imsg-watch-stderr.log</string>

	<key>RunAtLoad</key>
	<true/>

	<key>KeepAlive</key>
	<true/>

	<key>ThrottleInterval</key>
	<integer>5</integer>

	<key>EnvironmentVariables</key>
	<dict>
		<key>HOME</key>
		<string>/Users/jmg</string>
	</dict>
</dict>
</plist>
